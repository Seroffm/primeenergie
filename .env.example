# Kopiere diese Datei nach .env.local und trage die echten Werte ein.
# .env.local wird NICHT committed (.gitignore).

# ---------------------------------------------------------------------------
# Supabase – öffentliche Projekt-Daten (sicher im Frontend)
# Zu finden unter: https://app.supabase.com → Projekt → Settings → API
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------------------
# Backend-API-URL
# Live:   https://strom-sandy.vercel.app
# Lokal:  http://localhost:3000
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=https://strom-sandy.vercel.app

# ---------------------------------------------------------------------------
# Cloudflare Turnstile – öffentliche Schlüssel, darf VITE_ sein
# ---------------------------------------------------------------------------
# Site Key für das eingebundene Widget (Formular-Seite)
VITE_TURNSTILE_SITE_KEY=

# DEMO/STAGING ONLY – Cloudflare always-pass Testtoken.
# Wird verwendet wenn kein echtes Widget-Token vorhanden ist.
# NIEMALS in Production setzen — Production braucht ein echtes Turnstile-Widget.
# Cloudflare Testschlüssel-Paar (always-pass):
#   Site Key:    1x00000000000000000000AA
#   Secret Key:  1x0000000000000000000000000000000AA
#   Demo Token:  XXXX.DUMMY.TOKEN.XXXX
VITE_TURNSTILE_DEMO_TOKEN=

# ---------------------------------------------------------------------------
# Server-only (NIEMALS ins Frontend / kein VITE_-Präfix):
# ---------------------------------------------------------------------------

# Supabase Service Role Key (Settings → API → service_role)
# Umgeht RLS — nur serverseitig in API-Routen verwenden!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare Turnstile Secret Key (dashboard.cloudflare.com → Turnstile)
# Leer lassen in Dev — dann wird Verifikation übersprungen.
TURNSTILE_SECRET_KEY=
